# Hormigas Messenger integration — build-time frontend config (Vite).
# All defaults assume the app is served from the SAME origin as the Ory edge
# (e.g. https://hormi.isolutions.io), so paths are host-relative and the existing
# Kratos session cookie is sent automatically.

# Edge prefix the messenger is mounted under. Staging: /messenger
# (REST → /messenger/api/**, WS → /messenger/ws). Use "" if mounted at the root.
VITE_MESSENGER_BASE=/messenger

# Ory Kratos public API on the edge.
VITE_KRATOS_URL=/.ory/kratos/public

# --- Admin keys (X-Admin-Key) --------------------------------------------------
# ⚠️ SECURITY / TEMPORARY DEMO-ONLY: both keys are baked into the JS bundle at build
# time and are readable by anyone who loads the app. Use demo/scoped keys only and
# rotate after the demo. The real fix is a server-side proxy that holds the key so it
# never reaches the browser. NEVER commit real values — fill these in a local .env.
#
# These are TWO DIFFERENT keys for TWO backends (do not reuse one for both):
#   VITE_IDS_ADMIN_KEY       -> IDS/kratosgate /ids/admin/** user directory lookups
#   VITE_MESSENGER_ADMIN_KEY -> the messenger's own admin endpoints, e.g. POST /api/chats
# If VITE_MESSENGER_ADMIN_KEY is unset it falls back to VITE_IDS_ADMIN_KEY (single-key
# setups only); with distinct keys, chat provisioning 403s unless this is set correctly.
VITE_IDS_URL=/ids/admin
VITE_IDS_ADMIN_KEY=
VITE_MESSENGER_ADMIN_KEY=
