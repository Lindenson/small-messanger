# Hormigas Messenger integration — build-time frontend config (Vite).
# All defaults assume the app is served from the SAME origin as the Ory edge
# (e.g. https://hormi.isolutions.io), so paths are host-relative and the existing
# Kratos session cookie is sent automatically.

# Edge prefix the messenger is mounted under. Staging: /messenger
# (REST → /messenger/api/**, WS → /messenger/ws). Use "" if mounted at the root.
VITE_MESSENGER_BASE=/messenger

# Ory Kratos public API on the edge.
VITE_KRATOS_URL=/.ory/kratos/public
